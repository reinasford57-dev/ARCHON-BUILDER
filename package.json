{
  "name": "archon-builder",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "lint": "pnpm --filter backend lint && pnpm --filter frontend lint",
    "start": "pnpm --filter backend start"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.6.0"
  }
}
